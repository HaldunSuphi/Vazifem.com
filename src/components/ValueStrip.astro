---
const values = [
  {
    title: 'Şeffaf Süreç',
    description: 'Her aşamayı fotoğraflarla takip edin',
    icon: 'eye',
  },
  {
    title: 'Fotoğraflı Teslim',
    description: 'Bakım öncesi ve sonrası görseller',
    icon: 'camera',
  },
  {
    title: 'Onaylı Sağlayıcılar',
    description: 'Yerel hizmet ekipleri',
    icon: 'shield',
  },
];
---

<section class="bg-sand py-12 sm:py-16 section-reveal">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8 sm:gap-4">
      {values.map((value, index) => (
        <div class="flex-1 flex items-start gap-4 sm:justify-center">
          {/* Icon */}
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
            {value.icon === 'eye' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            )}
            {value.icon === 'camera' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            )}
            {value.icon === 'shield' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
          </div>
          {/* Text */}
          <div>
            <h3 class="text-sm font-semibold text-neutral-800 tracking-wide uppercase">{value.title}</h3>
            <p class="mt-0.5 text-sm text-neutral-500">{value.description}</p>
          </div>
          {/* Divider (desktop only, not on last) */}
          {index < values.length - 1 && (
            <div class="hidden sm:block w-px h-10 bg-neutral-300 ml-4" aria-hidden="true" />
          )}
        </div>
      ))}
    </div>
  </div>
</section>
