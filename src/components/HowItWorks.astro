---
const steps = [
  {
    number: '01',
    title: 'Talep Oluşturun',
    description: 'Hizmet türünü seçin, mezar bilgilerini girin. Tek seferlik veya düzenli bakım talebinizi kolayca oluşturun.',
    image: '/images/flow/step-1-request.jpg',
    position: 'top',
  },
  {
    number: '02',
    title: 'Teklifinizi Takip Edin',
    description: 'Talebinizin durumunu anlık takip edin. Teklif geldiğinde bildirim alın, detayları inceleyin.',
    image: '/images/flow/step-2-offers.jpg',
    position: 'top',
  },
  {
    number: '03',
    title: 'Süreci Takip Edin',
    description: 'Hizmetin her aşamasını adım adım izleyin. Fotoğraflı ilerleme raporlarıyla her şey kontrolünüz altında.',
    image: '/images/flow/step-3-tracking.jpg',
    position: 'top',
  },
  {
    number: '04',
    title: 'Onaylayın',
    description: 'Tamamlanan hizmeti fotoğraflarla inceleyin. Memnunsanız onaylayın, değilseniz geri bildirim verin.',
    image: '/images/flow/step-4-approval.jpg',
    position: 'bottom',
  },
];
---

<section id="nasil-calisir" class="py-16 sm:py-20 lg:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {/* Section title */}
    <div class="text-center mb-14 sm:mb-20 section-reveal">
      <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-neutral-900 mb-4">
        Nasıl Çalışır?
      </h2>
      <p class="text-neutral-500 text-lg max-w-xl mx-auto">
        Dört basit adımda güvenilir bakım hizmeti alın.
      </p>
    </div>

    {/* Steps */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      {steps.map((step, index) => (
        <div class="section-reveal flex flex-col items-center text-center relative" style={`transition-delay: ${index * 150}ms`}>
          {/* Phone mockup */}
          <div class="relative mb-10 w-52 sm:w-56">
            {/* Shadow beneath phone */}
            <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 w-3/4 h-6 bg-neutral-900/10 rounded-full blur-xl" />

            {/* Phone body */}
            <div class="relative bg-neutral-900 rounded-[2.5rem] p-[10px] shadow-2xl ring-1 ring-neutral-700/50">
              {/* Side buttons */}
              <div class="absolute -left-[2px] top-24 w-[3px] h-8 bg-neutral-700 rounded-l-sm" />
              <div class="absolute -left-[2px] top-36 w-[3px] h-12 bg-neutral-700 rounded-l-sm" />
              <div class="absolute -left-[2px] top-[200px] w-[3px] h-12 bg-neutral-700 rounded-l-sm" />
              <div class="absolute -right-[2px] top-32 w-[3px] h-16 bg-neutral-700 rounded-r-sm" />

              {/* Screen area */}
              <div class="relative rounded-[2rem] overflow-hidden bg-white">
                {/* Status bar */}
                <div class="relative bg-white z-10 px-5 pt-2.5 pb-1 flex items-center justify-between">
                  <span class="text-[10px] font-semibold text-neutral-900">9:41</span>
                  {/* Dynamic Island */}
                  <div class="absolute left-1/2 -translate-x-1/2 top-1.5 w-[72px] h-[22px] bg-neutral-900 rounded-full" />
                  <div class="flex items-center gap-0.5">
                    <svg class="w-3.5 h-3.5 text-neutral-900" viewBox="0 0 24 24" fill="currentColor"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
                    <svg class="w-3.5 h-3.5 text-neutral-900" viewBox="0 0 24 24" fill="currentColor"><path d="M15.67 4H14V2h-4v2H8.33C7.6 4 7 4.6 7 5.33v15.33C7 21.4 7.6 22 8.33 22h7.33c.74 0 1.34-.6 1.34-1.33V5.33C17 4.6 16.4 4 15.67 4z"/></svg>
                  </div>
                </div>

                {/* Screenshot content */}
                <div class="relative aspect-[9/17] overflow-hidden">
                  <img
                    src={step.image}
                    alt={step.title}
                    class="absolute inset-0 w-full h-auto min-h-full object-cover"
                    style={step.position === 'bottom' ? 'object-position: center bottom' : 'object-position: center top'}
                    loading="lazy"
                  />
                </div>

                {/* Home indicator */}
                <div class="bg-white py-2 flex justify-center">
                  <div class="w-24 h-1 bg-neutral-300 rounded-full" />
                </div>
              </div>
            </div>
          </div>

          {/* Step label */}
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-primary-100 text-primary-700 text-sm font-bold flex items-center justify-center ring-2 ring-primary-200">
              {step.number}
            </span>
            <h3 class="text-lg font-semibold text-neutral-800">{step.title}</h3>
          </div>
          <p class="text-neutral-500 text-[15px] leading-relaxed max-w-[260px]">
            {step.description}
          </p>

          {/* Connector arrow (desktop only, not on last item) */}
          {index < steps.length - 1 && (
            <div class="hidden lg:flex absolute right-0 top-[35%] translate-x-1/2 z-10 w-8 h-8 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-neutral-100">
              <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
