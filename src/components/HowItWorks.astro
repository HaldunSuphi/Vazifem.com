---
const steps = [
  {
    number: '01',
    title: 'Bakım talebi verin',
    description: 'Mezar bilgilerini girin, ihtiyacınız olan bakım türünü seçin.',
    icon: 'plus',
    label: 'Talep Oluşturun',
    bg: 'bg-primary-50',
    accent: 'text-primary-600',
  },
  {
    number: '02',
    title: 'Teklifleri alın',
    description: 'Bölgenizdeki hizmet sağlayıcılardan teklifleri karşılaştırın.',
    icon: 'list',
    label: 'Teklifleri Karşılaştırın',
    bg: 'bg-sand',
    accent: 'text-terracotta',
  },
  {
    number: '03',
    title: 'Süreci takip edin ve onaylayın',
    description: 'Fotoğraflı ilerleme raporlarıyla süreci kontrol edin, tamamlanınca onaylayın.',
    icon: 'check',
    label: 'Süreci Takip Edin',
    bg: 'bg-cream',
    accent: 'text-primary-700',
  },
];
---

<section id="nasil-calisir" class="py-16 sm:py-20 lg:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {/* Section title */}
    <div class="text-center mb-14 sm:mb-16 section-reveal">
      <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-neutral-900 mb-4">
        Nasıl Çalışır?
      </h2>
      <p class="text-neutral-500 text-lg max-w-xl mx-auto">
        Üç basit adımda güvenilir bakım hizmeti alın.
      </p>
    </div>

    {/* Steps */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, index) => (
        <div class="section-reveal flex flex-col items-center text-center relative" style={`transition-delay: ${index * 150}ms`}>
          {/* Phone mockup */}
          <div class="relative mb-8 w-48 sm:w-56">
            {/* Phone frame */}
            <div class="relative bg-neutral-800 rounded-[2rem] p-2 shadow-xl">
              {/* Notch */}
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-neutral-800 rounded-b-xl z-10" />
              {/* Screen with placeholder */}
              <div class={`relative rounded-[1.5rem] overflow-hidden ${step.bg} aspect-[9/16] flex flex-col items-center justify-center p-6`}>
                {/* Icon */}
                <div class={`w-14 h-14 rounded-full bg-white/80 flex items-center justify-center mb-4 shadow-sm`}>
                  {step.icon === 'plus' && (
                    <svg class={`w-7 h-7 ${step.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  )}
                  {step.icon === 'list' && (
                    <svg class={`w-7 h-7 ${step.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                    </svg>
                  )}
                  {step.icon === 'check' && (
                    <svg class={`w-7 h-7 ${step.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                </div>
                {/* Label */}
                <span class={`text-sm font-medium ${step.accent}`}>{step.label}</span>
                {/* Placeholder UI elements */}
                <div class="space-y-2 w-full mt-6">
                  <div class="h-2.5 bg-neutral-900/5 rounded-full w-3/4 mx-auto" />
                  <div class="h-2.5 bg-neutral-900/5 rounded-full w-1/2 mx-auto" />
                  <div class="h-9 bg-neutral-900/5 rounded-lg w-full mt-3" />
                  <div class="h-9 bg-neutral-900/5 rounded-lg w-full" />
                </div>
              </div>
            </div>
          </div>

          {/* Text */}
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 text-sm font-bold flex items-center justify-center">
              {step.number}
            </span>
            <h3 class="text-lg font-semibold text-neutral-900">{step.title}</h3>
          </div>
          <p class="text-neutral-500 text-sm leading-relaxed max-w-xs">
            {step.description}
          </p>

          {/* Connector arrow (desktop only, not on last item) */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute right-0 top-1/3 translate-x-1/2 z-10">
              <svg class="w-6 h-6 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
