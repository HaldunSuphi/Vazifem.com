---
const services = [
  {
    title: 'Düzenli Mezar Bakımı',
    description: 'Mevsimsel temizlik, çim bakımı ve çiçek dikimi dahil kapsamlı bakım hizmeti. Her ziyaret sonrası fotoğraflı rapor.',
    icon: 'calendar',
    reverse: false,
  },
  {
    title: 'Özel Gün Hazırlığı',
    description: 'Bayram, kandil ve özel günler öncesinde mezar hazırlığı. Zamanında teslim garantisi.',
    icon: 'star',
    reverse: true,
  },
  {
    title: 'Restorasyon ve Onarım',
    description: 'Mezar taşı temizliği, çatlak onarımı ve yenileme işlemleri. Öncesi-sonrası karşılaştırma.',
    icon: 'wrench',
    reverse: false,
  },
];
---

<section class="py-16 sm:py-20 lg:py-28 bg-cream">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    {/* Section title */}
    <div class="text-center mb-14 sm:mb-16 section-reveal">
      <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-neutral-900 mb-4">
        Hizmetlerimiz
      </h2>
    </div>

    {/* Service items */}
    <div class="space-y-12 sm:space-y-16">
      {services.map((service, index) => (
        <div
          class={`section-reveal flex flex-col ${service.reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-8 md:gap-12`}
          style={`transition-delay: ${index * 100}ms`}
        >
          {/* Visual placeholder */}
          <div class="flex-shrink-0 w-full md:w-2/5">
            <div class="aspect-[4/3] rounded-2xl bg-sand border border-neutral-200 flex flex-col items-center justify-center p-8">
              <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center mb-4">
                {service.icon === 'calendar' && (
                  <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                )}
                {service.icon === 'star' && (
                  <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                )}
                {service.icon === 'wrench' && (
                  <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
              </div>
              <p class="text-xs text-neutral-400 text-center">Gerçek fotoğraflar yakında</p>
            </div>
          </div>

          {/* Text */}
          <div class="flex-1">
            <h3 class="font-serif text-xl sm:text-2xl text-neutral-900 mb-3">{service.title}</h3>
            <p class="text-neutral-500 leading-relaxed">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
