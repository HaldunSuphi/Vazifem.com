---
const badges = [
  {
    title: 'Türkiye Genelinde Hizmet',
    icon: 'map',
  },
  {
    title: '7/24 WhatsApp Destek',
    icon: 'chat',
  },
  {
    title: 'Gizlilik ve Güvenlik',
    icon: 'lock',
  },
];
---

<section class="py-16 sm:py-20 lg:py-28 bg-sand">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    {/* Trust badges */}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-12 mb-16 section-reveal">
      {badges.map((badge) => (
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
            {badge.icon === 'map' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            )}
            {badge.icon === 'chat' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            )}
            {badge.icon === 'lock' && (
              <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            )}
          </div>
          <span class="text-sm font-medium text-neutral-700">{badge.title}</span>
        </div>
      ))}
    </div>

    {/* Founder quote */}
    <div class="section-reveal max-w-2xl mx-auto">
      <blockquote class="border-l-4 border-terracotta pl-6 sm:pl-8">
        <p class="font-serif text-xl sm:text-2xl text-neutral-800 italic leading-relaxed">
          "Bu hizmeti, kendi hayatımda ihtiyaç duyduğum için kurdum. Her aile aynı özeni hakediyor."
        </p>
        <footer class="mt-4">
          <span class="text-sm font-medium text-neutral-600">Haldun</span>
          <span class="text-neutral-400 mx-2">&mdash;</span>
          <span class="text-sm text-neutral-500">Vazifem Kurucu</span>
        </footer>
      </blockquote>
    </div>
  </div>
</section>
